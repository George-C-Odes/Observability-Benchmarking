<configuration>
    <!--
      Keep logs stable for benchmarking.
      Root log level is controlled by env/system property LOGGING_LEVEL_ROOT (defaults to INFO).
      Example: LOGGING_LEVEL_ROOT=DEBUG
    -->
    <property name="ROOT_LEVEL" value="${LOGGING_LEVEL_ROOT:-INFO}"/>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level [traceId=%X{traceId:-}, spanId=%X{spanId:-}] [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Keep span-drop warnings visible by default. Set OTEL_BSP_LOG_LEVEL=ERROR or OFF
         during intentionally sampled/load-test runs if you only want to suppress the noise. -->
    <logger name="io.opentelemetry.sdk.trace.export.BatchSpanProcessor" level="${OTEL_BSP_LOG_LEVEL:-WARN}"/>

    <root level="${ROOT_LEVEL}">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
