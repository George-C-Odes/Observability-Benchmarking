# ------------------------------------------------------------------
# requirements.in  — top-level dependencies for pip-compile
#
# Usage:
#   python -m pip install pip-tools
#   pip-compile --upgrade requirements.in          # → requirements.txt
#   pip-compile --upgrade --strip-extras requirements.in  # strip extras markers
#
# Only list *direct* dependencies here.  pip-compile resolves the
# full dependency tree and pins every version in requirements.txt.
# ------------------------------------------------------------------

