{
  "name": "nextjs-dash",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.12.1",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001 -H 0.0.0.0",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run -c vitest.config.node.ts && vitest run -c vitest.config.dom.ts",
    "test:node": "vitest run -c vitest.config.node.ts",
    "test:dom": "vitest run -c vitest.config.dom.ts",
    "test:fast": "vitest run -c vitest.config.node.ts --bail=1 && vitest run -c vitest.config.dom.ts --bail=1",
    "test:watch": "vitest -c vitest.config.dom.ts",
    "test:coverage": "vitest run -c vitest.config.node.ts --coverage && vitest run -c vitest.config.dom.ts --coverage",
    "test:coverage:node": "vitest run -c vitest.config.node.ts --coverage",
    "test:coverage:dom": "vitest run -c vitest.config.dom.ts --coverage"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "7.3.9",
    "@mui/material": "7.3.9",
    "@mui/material-nextjs": "7.3.9",
    "date-fns": "4.1.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "xml2js": "0.6.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/xml2js": "0.4.14",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint-config-next": "^16.2.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^29.0.1",
    "typescript": "6.0.2",
    "vitest": "^4.1.2"
  }
}
