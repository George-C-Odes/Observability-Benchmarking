<?xml version="1.0" encoding="UTF-8"?>
<!--
  Native-image logging configuration.

  IMPORTANT: Do NOT reference the OpenTelemetry Logback appender here.
  Logback is initialized at build time (required by Weld/JBoss Logging).
  If the OTEL appender class appears in logback.xml, Logback will instantiate
  it during analysis, placing it in the image heap. That conflicts with
  - -initialize-at-run-time=io.opentelemetry.instrumentation.logback
  causing a fatal GraalVM error.

  Instead, StartupListener programmatically creates, configures, and attaches
  the appender at runtime, then points it at Helidon Telemetry's OTel SDK.
-->
<configuration>

    <!-- Suppress Logback's internal status messages -->
    <statusListener class="ch.qos.logback.core.status.NopStatusListener" />

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Keep span-drop warnings visible by default. Set OTEL_BSP_LOG_LEVEL=ERROR or OFF
         during intentionally sampled/load-test runs if you only want to suppress the noise. -->
    <logger name="io.opentelemetry.sdk.trace.export.BatchSpanProcessor" level="${OTEL_BSP_LOG_LEVEL:-WARN}" />
    <logger name="io.opentelemetry.sdk.trace.export.BatchSpanProcessor$Worker" level="${OTEL_BSP_LOG_LEVEL:-WARN}" />

    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>

</configuration>