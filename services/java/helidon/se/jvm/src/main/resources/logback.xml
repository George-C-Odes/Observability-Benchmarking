<?xml version="1.0" encoding="UTF-8"?>
<!-- src/main/resources/logback.xml -->
<configuration>

    <!-- Suppress Logback's internal status messages -->
    <statusListener class="ch.qos.logback.core.status.NopStatusListener" />

    <!-- Standard console output -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- OTel Java Agent already auto-instruments Logback for log capture.
         An explicit OpenTelemetryAppender would double-process every log statement
         through the OTel BatchLogRecordProcessor pipeline. Removed. -->

    <!-- Suppress noisy Helidon / Netty / OTel framework logging on hot path -->
    <logger name="io.helidon"          level="WARN" />
    <logger name="io.netty"            level="WARN" />
    <logger name="io.opentelemetry"    level="WARN" />

    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>

</configuration>