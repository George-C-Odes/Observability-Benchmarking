<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level [traceId=%X{traceId:-}, spanId=%X{spanId:-}] [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Keep span-drop warnings visible by default. Set OTEL_BSP_LOG_LEVEL=ERROR or OFF
         during intentionally sampled/load-test runs if you only want to suppress the noise. -->
    <logger name="io.opentelemetry.sdk.trace.export.BatchSpanProcessor" level="${OTEL_BSP_LOG_LEVEL:-WARN}"/>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
